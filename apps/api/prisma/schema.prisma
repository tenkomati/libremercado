generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  BLOCKED
  PENDING_REVIEW
}

enum UserRole {
  USER
  OPS
  ADMIN
}

enum KycStatus {
  PENDING
  APPROVED
  REJECTED
  REQUIRES_REVIEW
}

enum KycDocumentType {
  DNI
  CUIL
  CUIT
  PASSPORT
}

enum ListingStatus {
  DRAFT
  PUBLISHED
  RESERVED
  SOLD
  PAUSED
  UNDER_REVIEW
  REMOVED
}

enum ListingCondition {
  NEW
  LIKE_NEW
  VERY_GOOD
  GOOD
  FAIR
}

enum CurrencyCode {
  ARS
  USD
}

enum ProductMediaType {
  IMAGE
  VIDEO
}

enum ListingDraftStatus {
  OPEN
  PUBLISHED
  ABANDONED
}

enum ListingDraftStep {
  PRODUCT_MATCH
  GALLERY
  SECURITY
  LOGISTICS
  REVIEW
}

enum EscrowStatus {
  FUNDS_PENDING
  FUNDS_HELD
  SHIPPED
  DELIVERED
  DISPUTED
  RELEASED
  CANCELLED
  REFUNDED
}

enum OrderStatusScope {
  PAYMENT
  SHIPPING
  LEGACY
}

enum EscrowPaymentStatus {
  PAYMENT_PENDING
  PAYMENT_RECEIVED
  PAYMENT_RELEASED
  DISPUTED
  PAYMENT_CANCELLED
  PAYMENT_REFUNDED
}

enum EscrowShippingStatus {
  WAITING_DISPATCH
  IN_TRANSIT
  READY_FOR_PICKUP
  DELIVERED
  RETURNING
  WAITING_MEETING
  AT_MEETING_POINT
  QR_CONFIRMED
}

enum EscrowEventType {
  CREATED
  FUNDS_HELD
  SHIPPED
  DELIVERED
  DISPUTED
  RELEASED
  CANCELLED
  REFUNDED
}

enum FuelStationBrand {
  YPF
  SHELL
  AXION
}

enum MeetingProposalStatus {
  PENDING
  ACCEPTED
  DECLINED
  CANCELLED
}

enum AvailabilitySlotStatus {
  OPEN
  SELECTED
  CANCELLED
}

enum DeliveryMethod {
  MESSAGING
  COURIER
  SAFE_MEETING
  PICKUP
}

enum DeliveryProposalStatus {
  PENDING
  ACCEPTED
  DECLINED
  CANCELLED
}

enum NotificationType {
  MEETING_PROPOSED
  MEETING_RESPONDED
  AVAILABILITY_ADDED
  AVAILABILITY_SELECTED
  ESCROW_MESSAGE
  DELIVERY_PROPOSED
  DELIVERY_RESPONDED
  KYC_REVIEWED
  PAYMENT_UPDATED
}

enum PaymentProvider {
  SANDBOX
  MERCADO_PAGO
  MOBBEX
}

enum PaymentStatus {
  PAYMENT_PENDING
  PAYMENT_APPROVED
  FUNDS_HELD
  READY_TO_RELEASE
  RELEASED
  REFUNDED
  DISPUTED
  FAILED
}

enum InsurancePolicyStatus {
  PENDING
  ACTIVE
  CLAIMED
}

model User {
  id               String              @id @default(cuid())
  publicSerial     Int                 @unique @default(autoincrement())
  email            String              @unique
  dni              String              @unique
  passwordHash     String
  firstName        String
  lastName         String
  phone            String?
  province         String
  city             String
  status           UserStatus          @default(ACTIVE)
  role             UserRole            @default(USER)
  kycStatus        KycStatus           @default(PENDING)
  reputationScore  Decimal             @default(5.0) @db.Decimal(3, 2)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  kycVerifications KycVerification[]
  listings         Listing[]
  products         Product[]
  listingDrafts    ListingDraft[]
  buyerEscrows     EscrowTransaction[] @relation("EscrowBuyer")
  sellerEscrows    EscrowTransaction[] @relation("EscrowSeller")
  meetingProposals EscrowMeetingProposal[]
  deliveryProposals EscrowDeliveryProposal[]
  availabilitySlots EscrowAvailabilitySlot[] @relation("AvailabilityCreatedBy")
  selectedAvailabilitySlots EscrowAvailabilitySlot[] @relation("AvailabilitySelectedBy")
  escrowMessages    EscrowMessage[]
  buyerPaymentIntents PaymentIntent[] @relation("PaymentBuyer")
  sellerPaymentIntents PaymentIntent[] @relation("PaymentSeller")
  notifications     UserNotification[]
  adminAuditLogs   AdminAuditLog[]
  passwordResetTokens PasswordResetToken[]

  @@index([status])
  @@index([role])
  @@index([kycStatus])
  @@index([province, city])
}

model PasswordResetToken {
  id          String    @id @default(cuid())
  userId      String
  tokenHash   String    @unique
  expiresAt   DateTime
  usedAt      DateTime?
  requestedIp String?
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, usedAt, expiresAt])
  @@index([expiresAt])
}

model AdminAuditLog {
  id          String   @id @default(cuid())
  actorUserId String
  actorRole   UserRole
  action      String
  resourceType String
  resourceId  String
  metadata    Json?
  createdAt   DateTime @default(now())
  actor       User     @relation(fields: [actorUserId], references: [id], onDelete: Restrict)

  @@index([actorUserId, createdAt])
  @@index([resourceType, resourceId, createdAt])
  @@index([createdAt])
}

model PlatformSettings {
  id                         String       @id @default("global")
  sellerCommissionPercentage Decimal      @default(5.00) @db.Decimal(5, 2)
  buyerCommissionPercentage  Decimal      @default(0.00) @db.Decimal(5, 2)
  fixedListingFee            Decimal      @default(0.00) @db.Decimal(12, 2)
  fixedTransactionFee        Decimal      @default(0.00) @db.Decimal(12, 2)
  defaultCurrency            CurrencyCode @default(ARS)
  allowUsdListings           Boolean      @default(true)
  updatedByUserId            String?
  createdAt                  DateTime     @default(now())
  updatedAt                  DateTime     @updatedAt
}

model CatalogProduct {
  id             String   @id @default(cuid())
  externalRef    String   @unique
  slug           String   @unique
  title          String
  brand          String?
  model          String?
  category       String
  releaseYear    Int?
  technicalSpecs Json?
  searchAliases  String[]   @default([])
  defaultImageUrl String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  products       Product[]
  listingDrafts  ListingDraft[] @relation("DraftCatalogProduct")

  @@index([category, isActive])
  @@index([title, isActive])
}

model Product {
  id                    String           @id @default(cuid())
  sellerId              String
  catalogProductId      String?
  title                 String?
  slugBase              String?
  brand                 String?
  model                 String?
  category              String?
  manufactureYear       Int?
  description           String?
  condition             ListingCondition?
  serialNumber          String?
  imei                  String?
  invoiceVerified       Boolean          @default(false)
  transparencyBadge     Boolean          @default(false)
  technicalSpecs        Json?
  searchTags            String[]           @default([])
  marketTags            String[]           @default([])
  visionSummary         Json?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  seller                User             @relation(fields: [sellerId], references: [id], onDelete: Restrict)
  catalogProduct        CatalogProduct?  @relation(fields: [catalogProductId], references: [id], onDelete: SetNull)
  media                 ProductMedia[]
  listingDrafts         ListingDraft[]
  listing               Listing?

  @@index([sellerId, updatedAt])
  @@index([category, condition])
}

model ProductMedia {
  id                      String           @id @default(cuid())
  productId               String
  type                    ProductMediaType
  url                     String
  sortOrder               Int              @default(0)
  aiBlurDetected          Boolean          @default(false)
  aiNoisyBackground       Boolean          @default(false)
  aiVisibleDamage         Boolean          @default(false)
  aiQualityScore          Int              @default(0)
  aiSuggestion            String?
  createdAt               DateTime         @default(now())
  updatedAt               DateTime         @updatedAt
  product                 Product          @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, type, sortOrder])
}

model ListingDraft {
  id                    String             @id @default(cuid())
  sellerId              String
  productId             String
  matchedCatalogProductId String?
  status                ListingDraftStatus @default(OPEN)
  currentStep           ListingDraftStep   @default(PRODUCT_MATCH)
  searchQuery           String?
  referenceImageUrl     String?
  targetNetAmount       Decimal?           @db.Decimal(12, 2)
  askingPrice           Decimal?           @db.Decimal(12, 2)
  shippingFeeEstimate   Decimal?           @db.Decimal(12, 2)
  insuranceFeeEstimate  Decimal?           @db.Decimal(12, 2)
  currency              CurrencyCode       @default(ARS)
  locationProvince      String?
  locationCity          String?
  deliveryMethods       DeliveryMethod[]   @default([])
  insuranceSelected     Boolean            @default(false)
  hasFunctionalityVideo Boolean            @default(false)
  publishedListingId    String?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  seller                User               @relation(fields: [sellerId], references: [id], onDelete: Restrict)
  product               Product            @relation(fields: [productId], references: [id], onDelete: Cascade)
  matchedCatalogProduct CatalogProduct?    @relation("DraftCatalogProduct", fields: [matchedCatalogProductId], references: [id], onDelete: SetNull)

  @@index([sellerId, status, updatedAt])
  @@index([productId, status])
}

model KycVerification {
  id             String          @id @default(cuid())
  userId         String
  provider       String
  documentType   KycDocumentType
  documentNumber String
  documentFrontImageUrl String?
  documentBackImageUrl  String?
  selfieImageUrl        String?
  biometricConsentAt    DateTime?
  status         KycStatus       @default(PENDING)
  riskScore      Decimal?        @db.Decimal(5, 2)
  faceMatchScore Decimal?        @db.Decimal(5, 2)
  reviewerNotes  String?
  reviewedAt     DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([provider, documentNumber])
}

model Listing {
  id               String              @id @default(cuid())
  sellerId         String
  productId        String?             @unique
  title            String
  slug             String?             @unique
  description      String
  category         String
  condition        ListingCondition
  status           ListingStatus       @default(DRAFT)
  price            Decimal             @db.Decimal(12, 2)
  currency         CurrencyCode        @default(ARS)
  locationProvince String
  locationCity     String
  aiSuggestedPrice Decimal?            @db.Decimal(12, 2)
  autoTags         String[]             @default([])
  marketTags       String[]             @default([])
  publishedAt      DateTime?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  seller           User                @relation(fields: [sellerId], references: [id], onDelete: Restrict)
  product          Product?            @relation(fields: [productId], references: [id], onDelete: SetNull)
  images           ListingImage[]
  escrows          EscrowTransaction[]

  @@index([sellerId, status])
  @@index([category, status])
  @@index([locationProvince, locationCity, status])
  @@index([slug])
}

model ListingImage {
  id        String   @id @default(cuid())
  listingId String
  url       String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId, sortOrder])
}

model EscrowTransaction {
  id                  String          @id @default(cuid())
  publicSerial        Int             @unique @default(autoincrement())
  listingId           String
  buyerId             String
  sellerId            String
  amount              Decimal         @db.Decimal(12, 2)
  feePercentage       Decimal         @db.Decimal(5, 2)
  feeAmount           Decimal         @db.Decimal(12, 2)
  netAmount           Decimal         @db.Decimal(12, 2)
  isInsured           Boolean         @default(false) @map("is_insured")
  insuranceFee        Decimal         @default(0) @db.Decimal(12, 2) @map("insurance_fee")
  currency            CurrencyCode    @default(ARS)
  paymentStatus       EscrowPaymentStatus @default(PAYMENT_PENDING)
  shippingStatus      EscrowShippingStatus?
  status              EscrowStatus    @default(FUNDS_HELD)
  shippingProvider    String
  shippingTrackingCode String?
  shippedAt           DateTime?
  deliveredAt         DateTime?
  releaseEligibleAt   DateTime?
  releasedAt          DateTime?
  disputeReason       String?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  listing             Listing         @relation(fields: [listingId], references: [id], onDelete: Restrict)
  buyer               User            @relation("EscrowBuyer", fields: [buyerId], references: [id], onDelete: Restrict)
  seller              User            @relation("EscrowSeller", fields: [sellerId], references: [id], onDelete: Restrict)
  events              EscrowEvent[]
  meetingProposals    EscrowMeetingProposal[]
  deliveryProposals   EscrowDeliveryProposal[]
  availabilitySlots   EscrowAvailabilitySlot[]
  messages            EscrowMessage[]
  paymentIntents      PaymentIntent[]
  insurancePolicy     InsurancePolicy?
  orderHistory        OrderHistory[]

  @@index([buyerId, status])
  @@index([sellerId, status])
  @@index([listingId, status])
  @@index([buyerId, paymentStatus])
  @@index([sellerId, paymentStatus])
  @@index([listingId, paymentStatus])
  @@index([buyerId, shippingStatus])
  @@index([sellerId, shippingStatus])
  @@index([listingId, shippingStatus])
}

model OrderHistory {
  id          String           @id @default(cuid())
  escrowId    String
  scope       OrderStatusScope
  fromStatus  String?
  toStatus    String
  note        String?
  metadata    Json?
  createdAt   DateTime         @default(now())
  escrow      EscrowTransaction @relation(fields: [escrowId], references: [id], onDelete: Cascade)

  @@index([escrowId, createdAt])
  @@index([scope, createdAt])
}

model PaymentIntent {
  id                   String          @id @default(cuid())
  escrowId             String
  buyerId              String
  sellerId             String
  provider             PaymentProvider
  status               PaymentStatus   @default(PAYMENT_PENDING)
  amount               Decimal         @db.Decimal(12, 2)
  feeAmount            Decimal         @db.Decimal(12, 2)
  netAmount            Decimal         @db.Decimal(12, 2)
  currency             CurrencyCode    @default(ARS)
  checkoutUrl          String?
  providerPaymentId    String?
  providerPreferenceId String?
  providerStatus       String?
  providerRawPayload   Json?
  approvedAt           DateTime?
  fundsHeldAt          DateTime?
  readyToReleaseAt     DateTime?
  releasedAt           DateTime?
  refundedAt           DateTime?
  failedAt             DateTime?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  escrow               EscrowTransaction @relation(fields: [escrowId], references: [id], onDelete: Cascade)
  buyer                User            @relation("PaymentBuyer", fields: [buyerId], references: [id], onDelete: Restrict)
  seller               User            @relation("PaymentSeller", fields: [sellerId], references: [id], onDelete: Restrict)
  events               PaymentEvent[]

  @@index([escrowId, status])
  @@index([buyerId, status, createdAt])
  @@index([sellerId, status, createdAt])
  @@index([provider, providerPaymentId])
  @@index([provider, providerPreferenceId])
}

model PaymentEvent {
  id              String        @id @default(cuid())
  paymentIntentId String
  provider        PaymentProvider
  status          PaymentStatus
  providerEventId String?
  rawPayload      Json?
  createdAt       DateTime      @default(now())
  paymentIntent   PaymentIntent @relation(fields: [paymentIntentId], references: [id], onDelete: Cascade)

  @@index([paymentIntentId, createdAt])
  @@index([provider, providerEventId])
}

model InsuranceProvider {
  id          String            @id @default(cuid())
  name        String            @unique
  endpointApi String            @map("endpoint_api")
  apiKey      String            @map("api_key")
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")
  policies    InsurancePolicy[]

  @@map("insurance_providers")
}

model InsurancePolicy {
  id               String               @id @default(cuid())
  escrowId         String               @unique @map("order_id")
  providerId       String               @map("provider_id")
  externalPolicyId String               @unique @map("policy_id_externo")
  status           InsurancePolicyStatus @default(PENDING)
  premiumAmount    Decimal              @db.Decimal(12, 2) @map("premium_amount")
  coverageAmount   Decimal              @db.Decimal(12, 2) @map("coverage_amount")
  policyUrl        String               @map("policy_url")
  rawPayload       Json?                @map("raw_payload")
  createdAt        DateTime             @default(now()) @map("created_at")
  updatedAt        DateTime             @updatedAt @map("updated_at")
  escrow           EscrowTransaction    @relation(fields: [escrowId], references: [id], onDelete: Cascade)
  provider         InsuranceProvider    @relation(fields: [providerId], references: [id], onDelete: Restrict)

  @@index([providerId, status])
  @@index([status, createdAt])
  @@map("insurance_policies")
}

model EscrowDeliveryProposal {
  id              String                 @id @default(cuid())
  escrowId        String
  createdByUserId String
  method          DeliveryMethod
  details         String?
  status          DeliveryProposalStatus @default(PENDING)
  responseNote    String?
  respondedAt     DateTime?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  escrow          EscrowTransaction      @relation(fields: [escrowId], references: [id], onDelete: Cascade)
  createdBy       User                   @relation(fields: [createdByUserId], references: [id], onDelete: Restrict)

  @@index([escrowId, status])
  @@index([createdByUserId, createdAt])
  @@index([method, status])
}

model EscrowAvailabilitySlot {
  id               String                 @id @default(cuid())
  escrowId         String
  createdByUserId  String
  selectedByUserId String?
  startsAt         DateTime
  endsAt           DateTime
  status           AvailabilitySlotStatus @default(OPEN)
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  escrow           EscrowTransaction      @relation(fields: [escrowId], references: [id], onDelete: Cascade)
  createdBy        User                   @relation("AvailabilityCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  selectedBy       User?                  @relation("AvailabilitySelectedBy", fields: [selectedByUserId], references: [id], onDelete: Restrict)

  @@index([escrowId, status])
  @@index([createdByUserId, startsAt])
  @@index([selectedByUserId, startsAt])
}

model EscrowMessage {
  id           String             @id @default(cuid())
  escrowId     String
  senderUserId String
  body         String
  createdAt    DateTime           @default(now())
  escrow       EscrowTransaction  @relation(fields: [escrowId], references: [id], onDelete: Cascade)
  sender       User               @relation(fields: [senderUserId], references: [id], onDelete: Restrict)

  @@index([escrowId, createdAt])
  @@index([senderUserId, createdAt])
}

model UserNotification {
  id           String           @id @default(cuid())
  userId       String
  type         NotificationType
  title        String
  body         String
  resourceType String
  resourceId   String
  readAt       DateTime?
  createdAt    DateTime         @default(now())
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt, createdAt])
  @@index([resourceType, resourceId])
}

model EscrowMeetingProposal {
  id              String                @id @default(cuid())
  escrowId        String
  createdByUserId String
  brand           FuelStationBrand
  stationName     String
  address         String
  city            String
  province        String
  proposedAt      DateTime
  status          MeetingProposalStatus @default(PENDING)
  responseNote    String?
  respondedAt     DateTime?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  escrow          EscrowTransaction     @relation(fields: [escrowId], references: [id], onDelete: Cascade)
  createdBy       User                  @relation(fields: [createdByUserId], references: [id], onDelete: Restrict)

  @@index([escrowId, status])
  @@index([createdByUserId, createdAt])
  @@index([brand, city, province])
}

model EscrowEvent {
  id        String          @id @default(cuid())
  escrowId  String
  type      EscrowEventType
  payload   Json?
  createdAt DateTime        @default(now())
  escrow    EscrowTransaction @relation(fields: [escrowId], references: [id], onDelete: Cascade)

  @@index([escrowId, createdAt])
}
