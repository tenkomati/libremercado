# Staging/Beta environment template.
# Never commit a real .env.staging with secrets.

NODE_ENV=production

# Supabase Postgres.
# For the current Nest API as a server-based deployment, use Supavisor Session
# mode on port 5432 or the direct connection if the hosting network supports it.
DATABASE_URL="postgres://prisma.<PROJECT_REF>:<PRISMA_PASSWORD>@<REGION>.pooler.supabase.com:5432/postgres?connect_timeout=30&pool_timeout=30"

# Keep this documented for a future serverless/transaction-pool deployment.
# If Prisma schema enables directUrl later, this should point to Session mode
# or direct connection while DATABASE_URL uses Transaction mode with pgbouncer.
DIRECT_URL="postgres://prisma.<PROJECT_REF>:<PRISMA_PASSWORD>@<REGION>.pooler.supabase.com:5432/postgres?connect_timeout=30"

REDIS_URL="rediss://<USER>:<PASSWORD>@<HOST>:<PORT>"

NEXT_PUBLIC_API_URL="https://api-beta.libremercado.example"
APP_PUBLIC_URL="https://beta.libremercado.example"
PORT=3001

JWT_SECRET="<generate-a-long-random-secret>"
JWT_ACCESS_TOKEN_TTL_SECONDS=604800
PASSWORD_RESET_TOKEN_TTL_SECONDS=1800
DEFAULT_ESCROW_FEE_PERCENTAGE=5

PAYMENT_PROVIDER=SANDBOX
PAYMENT_CHECKOUT_BASE_URL="<provider-checkout-url-or-empty-for-sandbox>"
PAYMENT_WEBHOOK_SECRET="<fallback-webhook-secret>"
PAYMENT_WEBHOOK_SECRET_SANDBOX="<sandbox-webhook-secret>"
PAYMENT_WEBHOOK_SECRET_MOBBEX="<mobbex-webhook-secret>"
PAYMENT_WEBHOOK_SECRET_MERCADO_PAGO="<mercado-pago-webhook-secret>"

GOOGLE_MAPS_API_KEY="<google-maps-api-key>"

MEDIA_STORAGE_DRIVER=s3
MEDIA_PUBLIC_BASE_URL="https://cdn-beta.libremercado.example"
S3_ENDPOINT="https://<account-id>.r2.cloudflarestorage.com"
S3_REGION=auto
S3_BUCKET="libremercado-beta"
S3_ACCESS_KEY_ID="<access-key>"
S3_SECRET_ACCESS_KEY="<secret-key>"
S3_PUBLIC_BASE_URL="https://cdn-beta.libremercado.example"
S3_FORCE_PATH_STYLE=true

EMAIL_PROVIDER=log
EMAIL_FROM="LibreMercado Beta <no-reply@beta.libremercado.example>"
