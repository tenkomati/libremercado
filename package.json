{
  "name": "libremercado",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@10.9.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev:stop && concurrently --kill-others-on-fail --names web,api --prefix-colors blue,green \"npm run dev:web\" \"npm run dev:api\"",
    "dev:stop": "sh scripts/stop-dev-ports.sh",
    "dev:web": "npm run dev --workspace @libremercado/web",
    "dev:api": "npm run start:dev --workspace @libremercado/api",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "smoke:predeploy": "node --input-type=module -e \"import('./scripts/smoke-predeploy.mjs')\"",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "prettier": "^3.5.3"
  }
}
